Algoritmo "OrdemDecrescente"
// Disciplina : Lógica de Programação
// Professor  : Jailson Costa dos Santos
// Descrição  : Solicitar dois números ao usuario e retornar em ordem decrescente
// Autor  : Gabriel Henrique Alves Rocha
// Data atual : 05/04/2026
Var
   // Seção de Declarações das variáveis
   numero1,numero2:inteiro
Inicio
   // Seção de Comandos, procedimento, funções, operadores, etc...
   Escreval("Ordem decrescente")
   Escreva("Informe o primerio número:")
   Leia(numero1)
   Escreva("Informe o segundo número:")
   Leia(numero2)
   se numero1 < numero2 entao
      Escreva("A ordem decrescente dos numeros é: ",numero2,",",numero1)
   senao
      Escreva("A ordem decrescente dos numeros é: ",numero1,",",numero2)
   fimse
FimalgoritmO