Algoritmo "SomaDoisNumeros"
// Disciplina : Lógica de Programaçăo
// Professor  : Jailson Costa dos Santos
// Descriçăo  : Pedir 3 números e somar os dois maiores
// Autor  : Gabriel Henrique Alves Rocha
// Data atual : 01/04/2026
Var
// Seçăo de Declaraçőes das variáveis 
numero1,numero2, numero3, soma : inteiro

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
Escreval("Soma dos dois maiores números")
Escreva("Digite o primeiro numero: ")
   Leia(numero1)

   Escreva("Digite o segundo numero: ")
   Leia(numero2)

   Escreva("Digite o terceiro numero: ")
   Leia(numero3)

   se (numero1 < numero2) e (numero1 < numero3) entao
      soma <- numero2 + numero3
   senao
      se (numero2 < numero1) e (numero2 < numero3) entao
         soma <- numero1 + numero3
      senao
         soma  <- numero2 + numero1
      fimse
   fimse

   Escreval("A soma dos maiores valores é: ", soma)

Fimalgoritmo