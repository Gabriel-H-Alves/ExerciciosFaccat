Algoritmo "CodigoUsuario"
// Disciplina : Lógica de Programaçăo
// Professor  : Jailson Costa dos Santos
// Descriçăo  : Verificar se o codigo do usuario esta correto
// Autor   : Gabriel Henrique Alves Rocha
// Data atual : 10/04/2026
Var
   // Seçăo de Declaraçőes das variáveis
   usuario, senha, usuarioCorreto, senhaCorreta:caractere
Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   Escreval("Verificar o codigo do usuario")
   usuarioCorreto<-"1234"
   senhaCorreta<-"9999"
   Escreval("Digite seu usuário: ")
   Leia(usuario)

   se usuario = usuarioCorreto entao
      Escreva("Digite sua senha: ")
      Leia(senha)
      se senha = senhaCorreta entao
         Escreva("Acesso permitido")
      senao
         Escreva("Senha incorreta")
      fimse
   senao
      Escreva("Usuário inválido")
   fimse

Fimalgoritmo